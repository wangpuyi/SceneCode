<?xml version="1.0"?>
<sdf version="1.8">
  <model name="articulated_cabinet">
    <link name="base_link">
      <inertial>
        <mass>10.0</mass>
        <inertia>
          <ixx>1.0</ixx>
          <iyy>1.0</iyy>
          <izz>1.0</izz>
        </inertia>
      </inertial>
      <visual name="base_visual">
        <pose>0 0 0.5 0 0 0</pose>
        <geometry>
          <mesh>
            <uri>cube.obj</uri>
            <scale>1.0 0.5 1.0</scale>
          </mesh>
        </geometry>
      </visual>
      <collision name="base_collision_1">
        <pose>0 0 0.5 0 0 0</pose>
        <geometry>
          <mesh>
            <uri>cube.obj</uri>
            <scale>1.0 0.5 1.0</scale>
          </mesh>
        </geometry>
      </collision>
      <collision name="base_collision_2">
        <pose>0 0 0.2 0 0 0</pose>
        <geometry>
          <mesh>
            <uri>cube.obj</uri>
            <scale>0.9 0.45 0.4</scale>
          </mesh>
        </geometry>
      </collision>
    </link>

    <link name="door_link">
      <pose>0.5 0 0.5 0 0 0</pose>
      <inertial>
        <mass>1.0</mass>
        <inertia>
          <ixx>0.1</ixx>
          <iyy>0.1</iyy>
          <izz>0.1</izz>
        </inertia>
      </inertial>
      <visual name="door_visual">
        <pose>0 0.26 0 0 0 0</pose>
        <geometry>
          <mesh>
            <uri>cube.obj</uri>
            <scale>0.02 0.5 1.0</scale>
          </mesh>
        </geometry>
      </visual>
      <collision name="door_collision_1">
        <pose>0 0.26 0 0 0 0</pose>
        <geometry>
          <mesh>
            <uri>cube.obj</uri>
            <scale>0.02 0.5 1.0</scale>
          </mesh>
        </geometry>
      </collision>
      <collision name="door_collision_2">
        <pose>0 0.26 0.2 0 0 0</pose>
        <geometry>
          <mesh>
            <uri>cube.obj</uri>
            <scale>0.02 0.4 0.6</scale>
          </mesh>
        </geometry>
      </collision>
    </link>

    <joint name="door_hinge" type="revolute">
      <parent>base_link</parent>
      <child>door_link</child>
      <pose>0.5 0 0.5 0 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>0</lower>
          <upper>1.57</upper>
        </limit>
      </axis>
    </joint>

    <link name="drawer_link">
      <pose>0 0 0.2 0 0 0</pose>
      <inertial>
        <mass>1.0</mass>
        <inertia>
          <ixx>0.1</ixx>
          <iyy>0.1</iyy>
          <izz>0.1</izz>
        </inertia>
      </inertial>
      <visual name="drawer_visual">
        <geometry>
          <mesh>
            <uri>cube.obj</uri>
            <scale>0.6 0.4 0.2</scale>
          </mesh>
        </geometry>
      </visual>
      <collision name="drawer_collision_1">
        <geometry>
          <mesh>
            <uri>cube.obj</uri>
            <scale>0.6 0.4 0.2</scale>
          </mesh>
        </geometry>
      </collision>
      <collision name="drawer_collision_2">
        <pose>0 0 0.05 0 0 0</pose>
        <geometry>
          <mesh>
            <uri>cube.obj</uri>
            <scale>0.5 0.35 0.1</scale>
          </mesh>
        </geometry>
      </collision>
    </link>

    <joint name="drawer_slide" type="prismatic">
      <parent>base_link</parent>
      <child>drawer_link</child>
      <pose>0 0.25 0.2 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-0.3</lower>
          <upper>0</upper>
        </limit>
      </axis>
    </joint>
  </model>
</sdf>
